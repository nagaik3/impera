BOT_START_TIME = None

# ============================================================
# CONVERSATION STATE — para fluxos multi-step
# ============================================================

_conversations = {}  # chat_id -> {"step": ..., "data": {...}}


def get_conv(chat_id):
    return _conversations.get(chat_id)


def set_conv(chat_id, step, data=None):
    if chat_id not in _conversations:
        _conversations[chat_id] = {"step": step, "data": data or {}}
    else:
        _conversations[chat_id]["step"] = step
        if data:
            _conversations[chat_id]["data"].update(data)


def clear_conv(chat_id):
    _conversations.pop(chat_id, None)


# ============================================================
# TELEGRAM HELPERS
# ============================================================

def tg_request(method, data=None):
    url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/{method}"
    body = json.dumps(data).encode() if data else None
    req = urllib.request.Request(url, data=body, method="POST")
    req.add_header("Content-Type", "application/json")
    with urllib.request.urlopen(req, timeout=35) as resp:
        return json.loads(resp.read())


def send_msg(chat_id, text, reply_markup=None):
    chunks = []
    if len(text) <= 4000:
        chunks = [text]
    else:
        lines = text.split("\n")
        current = ""
        for line in lines:
            if len(current) + len(line) + 1 > 4000:
                chunks.append(current)
                current = line
            else:
                current += ("\n" + line) if current else line
        if current:
            chunks.append(current)

    for i, chunk in enumerate(chunks):
        payload = {"chat_id": chat_id, "text": chunk, "disable_web_page_preview": True}
        if reply_markup and i == len(chunks) - 1:
            payload["reply_markup"] = reply_markup
        try:
            tg_request("sendMessage", payload)
        except Exception as e:
            print(f"[{datetime.now().isoformat()}] Erro envio: {e}")


def answer_callback(callback_id):
    try:
        tg_request("answerCallbackQuery", {"callback_query_id": callback_id})
    except Exception:
        pass


