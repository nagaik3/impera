def criar_ask_nicho(chat_id):
    """Pede o nicho."""
    nichos = sorted(NICHOS.keys())
    rows = []
    row = []
    for n in nichos:
        row.append({"text": n, "callback_data": f"criar|nicho|{n}"})
        if len(row) == 4:
            rows.append(row)
            row = []
    if row:
        rows.append(row)
    rows.append([{"text": "Cancelar", "callback_data": "criar|cancelar|"}])
    send_msg(chat_id, "Selecione o nicho:", reply_markup={"inline_keyboard": rows})


