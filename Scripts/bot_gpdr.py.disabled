def criar_preview(chat_id):
    """Monta preview e pede confirmacao."""
    conv = get_conv(chat_id)
    if not conv:
        return
    d = conv["data"]

    tipo = d.get("tipo", "?")
    nicho = d.get("nicho", "?")
    mercado = d.get("mercado")
    oferta_sigla = d.get("oferta_sigla", "?")
    oferta_nome = d.get("oferta_nome", "?")
    fonte = d.get("fonte", "FB")
    qty = d.get("qty", 0)
    hooks = d.get("hooks", "V1")
    copywriter = d.get("copywriter", "?")
    rip_prefix = d.get("rip_prefix")
    otmz_nome = d.get("otmz_nome")
    var_ref = d.get("var_ref")
    batch_size = d.get("batch_size", 0)

    # Construir nome(s) previsto(s)
    mercado_part = f"[{mercado}]" if mercado else ""
    nicho_part = f"[{nicho}]{mercado_part}"

    if tipo == "vsl":
        name_preview = f"{nicho_part}[{oferta_sigla}][VSL]"
        qty_desc = "1 VSL"
    elif tipo == "otmz":
        otmz_clean = otmz_nome.upper().replace(" ", "_") if otmz_nome else "?"
        name_preview = f"{nicho_part}[{oferta_sigla}][OTMZ][{otmz_clean}]"
        qty_desc = "1 otimizacao"
    elif tipo in ("lead", "microlead"):
        sigla = "MLD" if tipo == "microlead" else "LD"
        name_preview = f"{nicho_part}[{oferta_sigla}][{sigla}01-{sigla}{qty:02d}]"
        qty_desc = f"{qty} {'microleads' if tipo == 'microlead' else 'leads'}"
    elif tipo == "ripagem":
        name_preview = f"{nicho_part}[RP][{oferta_sigla}][{fonte}][{rip_prefix}01-{rip_prefix}{qty:02d}]"
        qty_desc = f"{qty} ripagens ({rip_prefix})"
    elif tipo.startswith("variacoes"):
        is_img = tipo == "variacoes_img"
        img_tag = "-IMG" if is_img else ""
        name_preview = f"{nicho_part}[{oferta_sigla}][{fonte}][{var_ref}{img_tag}][V??-V??]"
        qty_desc = f"{qty} variacoes de {'imagem' if is_img else 'video'}"
    else:
        is_img = tipo == "novos_img"
        img_tag = "-IMG" if is_img else ""
        hook_count = hooks.count("V")
        total = qty * hook_count
        name_preview = f"{nicho_part}[{oferta_sigla}][{fonte}][AD??-AD??{img_tag}][{hooks}]"
        qty_desc = f"{qty} ADs x {hook_count} hooks = {total} criativos"

    batch_desc = ""
    if batch_size and batch_size > 0 and qty > batch_size:
        n_tasks = (qty + batch_size - 1) // batch_size
        batch_desc = f"\nDivisao: {n_tasks} tarefas de ate {batch_size}"

    preview = (
        f"PREVIEW DA TAREFA\n\n"
        f"Tipo: {TIPOS_TAREFA.get(tipo, tipo)}\n"
        f"Nome: {name_preview}\n"
        f"Quantidade: {qty_desc}{batch_desc}\n"
        f"Nicho: {nicho} ({NICHOS.get(nicho, {}).get('nome', '?')})\n"
        f"Oferta: {oferta_nome}\n"
        f"Copywriter: {copywriter}\n"
    )

    if fonte and tipo not in ("vsl", "otmz", "lead", "microlead"):
        preview += f"Fonte: {fonte}\n"

    keyboard = {"inline_keyboard": [
        [
            {"text": "Confirmar", "callback_data": "criar|confirmar|sim"},
            {"text": "Cancelar", "callback_data": "criar|cancelar|"},
        ],
    ]}
    send_msg(chat_id, preview, reply_markup=keyboard)
    set_conv(chat_id, "criar_confirm")


def criar_execute(chat_id):
    """Executa a criacao da tarefa no ClickUp."""
    conv = get_conv(chat_id)
    if not conv:
        send_msg(chat_id, "Erro: sessao expirada.")
        return
    d = conv["data"]

    tipo = d["tipo"]
    nicho = d["nicho"]
    mercado = d.get("mercado")
    oferta_sigla = d["oferta_sigla"]
    oferta_nome = d["oferta_nome"]
    fonte = d.get("fonte", "FB")
    qty = d.get("qty", 1)
    hooks = d.get("hooks", "V1")
    copywriter = d.get("copywriter")
    rip_prefix = d.get("rip_prefix")
    otmz_nome = d.get("otmz_nome")
    var_ref = d.get("var_ref")
    batch_size = d.get("batch_size", 0)

    mercado_part = f"[{mercado}]" if mercado else ""
    nicho_part = f"[{nicho}]{mercado_part}"

    send_msg(chat_id, "Criando tarefa(s)...")

    try:
        if tipo == "vsl":
            name = f"{nicho_part}[{oferta_sigla}][VSL]"
            task = create_task_with_checklists(
                name=name, copywriter=copywriter, nicho=nicho,
                oferta=oferta_nome,
            )
            send_msg(chat_id, f"Tarefa criada:\n{name}\n{task.get('url', '')}")

        elif tipo == "otmz":
            otmz_clean = otmz_nome.upper().replace(" ", "_")
            name = f"{nicho_part}[{oferta_sigla}][OTMZ][{otmz_clean}]"
            task = create_task_with_checklists(
                name=name, copywriter=copywriter, nicho=nicho,
                oferta=oferta_nome,
            )
            send_msg(chat_id, f"Tarefa criada:\n{name}\n{task.get('url', '')}")

        elif tipo in ("lead", "microlead"):
            sigla = "MLD" if tipo == "microlead" else "LD"
            name = f"{nicho_part}[{oferta_sigla}][{sigla}01-{sigla}{qty:02d}]"
            task = create_task_with_checklists(
                name=name, copywriter=copywriter, nicho=nicho,
                oferta=oferta_nome,
            )
            send_msg(chat_id, f"Tarefa criada:\n{name}\n{task.get('url', '')}")

        elif tipo == "ripagem":
            name = f"{nicho_part}[RP][{oferta_sigla}][{fonte}][{rip_prefix}01-{rip_prefix}{qty:02d}]"
            task = create_task_with_checklists(
                name=name, copywriter=copywriter, nicho=nicho,
                oferta=oferta_nome, fonte=fonte,
            )
            send_msg(chat_id, f"Tarefa criada:\n{name}\n{task.get('url', '')}")

        elif tipo.startswith("variacoes"):
            is_img = tipo == "variacoes_img"
            img_tag = "-IMG" if is_img else ""
            # Buscar ultima versao
            from clickup_criar_tarefa import get_last_version
            last_v = get_last_version(nicho, var_ref)
            tasks_created = []
            remaining = qty
            current_v = last_v + 1

            effective_batch = batch_size if batch_size > 0 else qty
            while remaining > 0:
                batch = min(remaining, effective_batch)
                v_start = current_v
                v_end = current_v + batch - 1
                name = f"{nicho_part}[{oferta_sigla}][{fonte}][{var_ref}{img_tag}][V{v_start}-V{v_end}]"
                task = create_task_with_checklists(
                    name=name, copywriter=copywriter, nicho=nicho,
                    oferta=oferta_nome, fonte=fonte,
                )
                tasks_created.append(name)
                current_v = v_end + 1
                remaining -= batch

            msg = f"{len(tasks_created)} tarefa(s) criada(s):\n" + "\n".join(tasks_created)
            send_msg(chat_id, msg)

        elif tipo in ("novos_video", "novos_img"):
            is_img = tipo == "novos_img"
            last_ad = get_last_ad_number(nicho, fonte)
            hook_count = hooks.count("V")
            tasks_created = []
            remaining = qty
            current_ad = last_ad + 1

            effective_batch = batch_size if batch_size > 0 else qty
            while remaining > 0:
                batch = min(remaining, effective_batch)
                ad_start = current_ad
                ad_end = current_ad + batch - 1
                if ad_start == ad_end:
                    ad_part = f"AD{ad_start}"
                else:
                    ad_part = f"AD{ad_start}-AD{ad_end}"
                if is_img:
                    ad_part += "-IMG"
                name = f"{nicho_part}[{oferta_sigla}][{fonte}][{ad_part}][{hooks}]"
                task = create_task_with_checklists(
                    name=name, copywriter=copywriter, nicho=nicho,
                    oferta=oferta_nome, fonte=fonte,
                )
                tasks_created.append(name)
                current_ad = ad_end + 1
                remaining -= batch

            total = qty * hook_count
            msg = f"{len(tasks_created)} tarefa(s) criada(s) ({total} criativos):\n" + "\n".join(tasks_created)
            send_msg(chat_id, msg)

        else:
            send_msg(chat_id, f"Tipo nao implementado: {tipo}")

    except Exception as e:
        send_msg(chat_id, f"Erro ao criar tarefa: {e}")

    clear_conv(chat_id)


def handle_criar_callback(chat_id, field, value):
    """Processa callbacks do fluxo /criar."""
    conv = get_conv(chat_id)

    if value == "" and field == "cancelar":
        clear_conv(chat_id)
        send_msg(chat_id, "Criacao cancelada.")
        return

    if field == "tipo":
        set_conv(chat_id, "criar_nicho", {"tipo": value})
        criar_ask_nicho(chat_id)

    elif field == "nicho":
        oferta_sigla = ""
        # Detectar oferta sigla baseado no nicho
        nicho_info = NICHOS.get(value, {})
        oferta_nome = nicho_info.get("oferta", "?")
        # Determinar sigla da oferta (OF01, OF02, etc.)
        oferta_map = {
            "EM": "OF02", "DB": "OFC01", "NE": "OF03", "MM": "OF01",
            "ME": "OF01", "DA": "OF02", "ED": "OF01", "PT": "OF01",
            "ZB": "OF01",
        }
        oferta_sigla = oferta_map.get(value, "OF01")

        set_conv(chat_id, "criar_mercado", {
            "nicho": value,
            "oferta_sigla": oferta_sigla,
            "oferta_nome": oferta_nome,
        })

        if value in NICHOS_COM_MERCADO_SET:
            criar_ask_mercado(chat_id)
        else:
            # Pular mercado, ir pra proximo step
            tipo = get_conv(chat_id)["data"]["tipo"]
            _criar_after_mercado(chat_id, tipo)

    elif field == "mercado":
        set_conv(chat_id, "criar_fonte", {"mercado": value})
        tipo = get_conv(chat_id)["data"]["tipo"]
        _criar_after_mercado(chat_id, tipo)

    elif field == "fonte":
        set_conv(chat_id, "criar_fonte_done", {"fonte": value})
        tipo = get_conv(chat_id)["data"]["tipo"]
        if tipo.startswith("variacoes"):
            criar_ask_var_ref(chat_id)
        else:
            criar_ask_qty(chat_id, tipo)

    elif field == "hooks":
        set_conv(chat_id, "criar_copy", {"hooks": value})
        criar_ask_copywriter(chat_id)

    elif field == "rip":
        set_conv(chat_id, "criar_qty", {"rip_prefix": value})
        criar_ask_qty(chat_id, "ripagem")

    elif field == "copy":
        set_conv(chat_id, "criar_batch", {"copywriter": value})
        tipo = get_conv(chat_id)["data"]["tipo"]
        qty = get_conv(chat_id)["data"].get("qty", 1)
        # Tipos que nao precisam de batch
        if tipo in ("vsl", "otmz", "lead", "microlead") or qty <= 1:
            set_conv(chat_id, "criar_preview", {"batch_size": 0})
            criar_preview(chat_id)
        else:
            criar_ask_batch(chat_id)

    elif field == "batch":
        set_conv(chat_id, "criar_preview", {"batch_size": int(value)})
        criar_preview(chat_id)

    elif field == "confirmar":
        criar_execute(chat_id)


def _criar_after_mercado(chat_id, tipo):
    """Decide proximo passo apos selecao de mercado."""
    if tipo == "vsl":
        criar_ask_copywriter(chat_id)
    elif tipo == "otmz":
        criar_ask_otmz_nome(chat_id)
    elif tipo in ("lead", "microlead"):
        criar_ask_qty(chat_id, tipo)
    elif tipo == "ripagem":
        criar_ask_rip_prefix(chat_id)
    elif tipo.startswith("variacoes"):
        criar_ask_fonte(chat_id)
    else:
        criar_ask_fonte(chat_id)


def handle_criar_text(chat_id, text):
    """Processa input de texto durante o fluxo /criar."""
    conv = get_conv(chat_id)
    if not conv:
        return False

    step = conv["step"]

    if step == "criar_qty":
        try:
            qty = int(text.strip())
            if qty <= 0:
                send_msg(chat_id, "Quantidade deve ser maior que zero.")
                return True
            set_conv(chat_id, "criar_hooks", {"qty": qty})
            tipo = conv["data"]["tipo"]
            if tipo in ("novos_video", "novos_img"):
                criar_ask_hooks(chat_id)
            elif tipo in ("lead", "microlead"):
                criar_ask_copywriter(chat_id)
            elif tipo == "ripagem":
                criar_ask_copywriter(chat_id)
            elif tipo.startswith("variacoes"):
                criar_ask_copywriter(chat_id)
            else:
                criar_ask_copywriter(chat_id)
        except ValueError:
            send_msg(chat_id, "Digite um numero valido.")
        return True

    elif step == "criar_otmz_nome":
        otmz_clean = text.strip().upper().replace(" ", "_")
        # Remover acentos simples
        for old, new in [("Á", "A"), ("É", "E"), ("Í", "I"), ("Ó", "O"), ("Ú", "U"),
                         ("Ã", "A"), ("Õ", "O"), ("Ç", "C"), ("Â", "A"), ("Ê", "E")]:
            otmz_clean = otmz_clean.replace(old, new)
        set_conv(chat_id, "criar_copy", {"otmz_nome": otmz_clean})
        criar_ask_copywriter(chat_id)
        return True

    elif step == "criar_var_ref":
        ref = text.strip().upper().replace(" ", "")
        set_conv(chat_id, "criar_qty", {"var_ref": ref})
        criar_ask_qty(chat_id, conv["data"]["tipo"])
        return True

    return False


# ============================================================
# /AUDITORIA — Rodar auditoria de nomenclatura
# ============================================================

def cmd_auditoria(chat_id):
    send_msg(chat_id, "Executando auditoria de nomenclatura...")
    issues = []

    for list_id, list_name in [(LIST_COPY, "COPY")]:
        tasks = fetch_tasks(list_id)
        for task in tasks:
            name = task["name"].strip()
            if not name.startswith("["):
                continue
            problems = validate_task_name(name)
            if problems:
                issues.append({
                    "id": task["id"],
                    "name": name,
                    "list": list_name,
                    "problems": problems,
                    "url": task.get("url", ""),
                })

    if not issues:
        send_msg(chat_id, "Nenhum problema de nomenclatura encontrado.")
        return

    lines = [f"AUDITORIA DE NOMENCLATURA\n{len(issues)} tarefa(s) com problemas:\n"]
    for i, issue in enumerate(issues[:15], 1):
        lines.append(f"{i}. [{issue['list']}] {issue['name'][:60]}")
        for p in issue["problems"]:
            lines.append(f"   -> {p}")
        lines.append("")

    if len(issues) > 15:
        lines.append(f"... e mais {len(issues) - 15} tarefas.")

    # Oferecer correcao
    fixable = [i for i in issues if _can_autofix(i)]
    if fixable:
        lines.append(f"\n{len(fixable)} tarefa(s) podem ser corrigidas automaticamente.")
        keyboard = {"inline_keyboard": [
            [{"text": f"Corrigir {len(fixable)} tarefas", "callback_data": "fix|all|"}],
            [{"text": "Cancelar", "callback_data": "fix|cancel|"}],
        ]}
        # Salvar issues fixaveis no state
        _conversations[chat_id] = {"step": "fix_pending", "data": {"fixable": fixable}}
        send_msg(chat_id, "\n".join(lines), reply_markup=keyboard)
    else:
        send_msg(chat_id, "\n".join(lines))


# ============================================================
# /CORRIGIR — Auto-fix de nomenclatura
# ============================================================

AUTOFIX_RULES = [
    # Mercado na posicao do nicho: [BR]EM] -> [EM][BR]
    (r'^\[BR\](\w{2})\]', lambda m: f'[{m.group(1)}][BR]'),
    (r'^\[EUA\](\w{2})\]', lambda m: f'[{m.group(1)}][EUA]'),
    # OTMZ junto: [OTMZ - NOME] ou [OTMZNOME] -> [OTMZ][NOME]
    (r'\[OTMZ\s*[-—]\s*([^\]]+)\]', lambda m: f'[OTMZ][{m.group(1).strip().upper().replace(" ", "_")}]'),
    (r'\[OTMZ([A-Z_][^\]]*)\]', lambda m: f'[OTMZ][{m.group(1).strip("_- ")}]'),
    # Espaco no range: [AD231- AD235] -> [AD231-AD235]
    (r'\[AD(\d+)\s*-\s*AD(\d+)\]', lambda m: f'[AD{m.group(1)}-AD{m.group(2)}]'),
    # [ML01-05] -> [MLD01-MLD05]
    (r'\[ML(\d+)-(\d+)\]', lambda m: f'[MLD{m.group(1)}-MLD{m.group(2)}]'),
    # NP -> NE
    (r'\[NP\]', lambda m: '[NE]'),
    # Remover acentos de OTMZ nome
    (r'\[OTMZ\]\[([^\]]*[ÁÉÍÓÚÃÕÇÂÊ][^\]]*)\]',
     lambda m: f'[OTMZ][{_remove_accents(m.group(1))}]'),
]


def _remove_accents(s):
    for old, new in [("Á", "A"), ("É", "E"), ("Í", "I"), ("Ó", "O"), ("Ú", "U"),
                     ("Ã", "A"), ("Õ", "O"), ("Ç", "C"), ("Â", "A"), ("Ê", "E"),
                     ("á", "a"), ("é", "e"), ("í", "i"), ("ó", "o"), ("ú", "u"),
                     ("ã", "a"), ("õ", "o"), ("ç", "c"), ("â", "a"), ("ê", "e")]:
        s = s.replace(old, new)
    return s.upper()


def _can_autofix(issue):
    """Verifica se um issue pode ser corrigido automaticamente."""
    fixed = _apply_autofix(issue["name"])
    return fixed != issue["name"]


def _apply_autofix(name):
    """Aplica todas as regras de autofix e retorna o nome corrigido."""
    fixed = name
    for pattern, replacement in AUTOFIX_RULES:
        fixed = re.sub(pattern, replacement, fixed)
    return fixed


def cmd_corrigir(chat_id):
    """Busca e corrige problemas de nomenclatura."""
    send_msg(chat_id, "Buscando tarefas com nomenclatura incorreta...")
    issues = []

    for list_id, list_name in [(LIST_COPY, "COPY")]:
        tasks = fetch_tasks(list_id)
        for task in tasks:
            name = task["name"].strip()
            if not name.startswith("["):
                continue
            fixed = _apply_autofix(name)
            if fixed != name:
                issues.append({
                    "id": task["id"],
                    "name": name,
                    "fixed": fixed,
                    "list": list_name,
                    "url": task.get("url", ""),
                })

    if not issues:
        send_msg(chat_id, "Nenhuma tarefa precisando de correcao automatica.")
        return

    lines = [f"CORRECOES DISPONIVEIS\n{len(issues)} tarefa(s):\n"]
    for i, issue in enumerate(issues[:15], 1):
        lines.append(f"{i}. {issue['name'][:50]}")
        lines.append(f"   -> {issue['fixed'][:50]}")
        lines.append("")

    keyboard = {"inline_keyboard": [
        [{"text": f"Corrigir {len(issues)} tarefas", "callback_data": "fix|execute|"}],
        [{"text": "Cancelar", "callback_data": "fix|cancel|"}],
    ]}
    _conversations[chat_id] = {"step": "fix_pending", "data": {"fixable_corrigir": issues}}
    send_msg(chat_id, "\n".join(lines), reply_markup=keyboard)


def fix_execute(chat_id, issues):
    """Executa as correcoes no ClickUp."""
    fixed_count = 0
    errors = []

    for issue in issues:
        new_name = issue.get("fixed") or _apply_autofix(issue["name"])
        if new_name == issue["name"]:
            continue
        try:
            api_request("PUT", f"/task/{issue['id']}", {"name": new_name})
            fixed_count += 1
        except Exception as e:
            errors.append(f"{issue['name'][:40]}: {e}")

    msg = f"Correcoes aplicadas: {fixed_count}/{len(issues)}"
    if errors:
        msg += f"\n\nErros ({len(errors)}):\n" + "\n".join(errors[:5])
    send_msg(chat_id, msg)


