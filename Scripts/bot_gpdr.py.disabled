# ============================================================
# /RELATORIO_PERFORMANCE_CRIATIVOS
# ============================================================

_pending_perf_criativos = {}  # chat_id -> True (esperando período digitado)


def cmd_relatorio_performance_criativos(chat_id):
    """Relatório de performance por criativo/copywriter."""
    now = datetime.now()
    # Smart presets
    # Semana passada (seg-dom)
    days_since_sunday = now.weekday() + 1
    if days_since_sunday == 7:
        days_since_sunday = 0
    last_sunday = now - timedelta(days=days_since_sunday)
    last_monday = last_sunday - timedelta(days=6)
    sem_passada = f"{last_monday.strftime('%d/%m')} a {last_sunday.strftime('%d/%m')}"
    sem_passada_key = f"{last_monday.strftime('%Y%m%d')}_{last_sunday.strftime('%Y%m%d')}"

    # Este mês
    first_day_month = now.replace(day=1)
    yesterday = now - timedelta(days=1)
    este_mes = f"01/{now.strftime('%m')} a {yesterday.strftime('%d/%m')}"
    este_mes_key = f"{first_day_month.strftime('%Y%m%d')}_{yesterday.strftime('%Y%m%d')}"

    # Mês passado
    last_month_end = first_day_month - timedelta(days=1)
    last_month_start = last_month_end.replace(day=1)
    mes_passado = f"{last_month_start.strftime('%d/%m')} a {last_month_end.strftime('%d/%m')}"
    mes_passado_key = f"{last_month_start.strftime('%Y%m%d')}_{last_month_end.strftime('%Y%m%d')}"

    buttons = [
        [{"text": f"Semana passada ({sem_passada})", "callback_data": f"rpc|period|{sem_passada_key}"}],
        [{"text": f"Este mês ({este_mes})", "callback_data": f"rpc|period|{este_mes_key}"}],
        [{"text": f"Mês passado ({mes_passado})", "callback_data": f"rpc|period|{mes_passado_key}"}],
        [{"text": "Digitar período (DD/MM-DD/MM)", "callback_data": "rpc|custom|0"}],
    ]
    send_msg(chat_id, "RELATÓRIO PERFORMANCE CRIATIVOS\n\nSelecione o período:", reply_markup={"inline_keyboard": buttons})


def rpc_execute(chat_id, date_from, date_to):
    """Executa geração do relatório em background."""
    import subprocess
    df_label = datetime.strptime(date_from, "%Y-%m-%d").strftime("%d/%m")
    dt_label = datetime.strptime(date_to, "%Y-%m-%d").strftime("%d/%m")
    send_msg(chat_id, f"Gerando relatório de performance por criativo ({df_label} a {dt_label})...\nIsso pode levar ~2 minutos.")

    try:
        result = subprocess.run(
            [sys.executable, os.path.expanduser("~/Scripts/relatorio_performance_criativos.py"),
             datetime.strptime(date_from, "%Y-%m-%d").strftime("%d/%m/%Y"),
             datetime.strptime(date_to, "%Y-%m-%d").strftime("%d/%m/%Y"),
             "--notify"],
            capture_output=True, text=True, timeout=600,
        )
        if result.returncode != 0:
            error = result.stderr or result.stdout or "Erro desconhecido"
            send_msg(chat_id, f"Erro ao gerar relatório:\n{error[:2000]}")
        else:
            send_msg(chat_id, "Relatório gerado e enviado!")
    except subprocess.TimeoutExpired:
        send_msg(chat_id, "Timeout: relatório demorou mais de 10 minutos.")
    except Exception as e:
        send_msg(chat_id, f"Erro: {e}")


def cmd_briefing(chat_id):
    """Gera e envia briefing diário sob demanda."""
    send_msg(chat_id, "Gerando briefing diário...")

    try:
        import subprocess
        result = subprocess.run(
            [sys.executable, os.path.expanduser("~/Scripts/briefing_diario.py")],
            capture_output=True, text=True, timeout=60,
            env={**os.environ},
        )

        # Ler o arquivo gerado (formato HTML para Telegram)
        briefing_path = os.path.expanduser("~/Scripts/data/briefing_diario_latest.txt")
        if os.path.exists(briefing_path):
            with open(briefing_path) as f:
                content = f.read()
            # O briefing_diario.py já enviou via Telegram com HTML,
            # mas usou o bot principal. Reenviar pelo bot GPDR em texto limpo.
            send_msg_long(chat_id, content)
        else:
            send_msg(chat_id, "Erro: arquivo de briefing nao gerado.")

        if result.returncode != 0:
            send_msg(chat_id, f"Aviso: script retornou codigo {result.returncode}\n{result.stderr[:200]}")

    except subprocess.TimeoutExpired:
        send_msg(chat_id, "Timeout ao gerar briefing (>60s).")
    except Exception as e:
        send_msg(chat_id, f"Erro ao gerar briefing: {e}")


def send_msg_long(chat_id, text, chunk_size=4000):
    """Envia mensagem longa dividindo em chunks."""
    if len(text) <= chunk_size:
        send_msg(chat_id, text)
        return
    lines = text.split("\n")
    current = ""
    for line in lines:
        if len(current) + len(line) + 1 > chunk_size:
            send_msg(chat_id, current)
            current = line
        else:
            current += "\n" + line if current else line
    if current:
        send_msg(chat_id, current)


def cmd_status(chat_id):
    now = datetime.now()
    uptime = ""
    if BOT_START_TIME:
        delta = now - BOT_START_TIME
        hours = int(delta.total_seconds() // 3600)
        mins = int((delta.total_seconds() % 3600) // 60)
        uptime = f"Uptime: {hours}h{mins:02d}m"

    convs = len(_conversations)
    lines = [
        f"STATUS BOT GPDR | {now.strftime('%d/%m/%Y %H:%M')}",
        "",
        "Bot: online",
        uptime,
        f"Conversas ativas: {convs}",
        f"ClickUp API: {'OK' if CLICKUP_TOKEN else 'NAO CONFIGURADO'}",
        f"Nichos: {', '.join(sorted(NICHOS.keys()))}",
        f"Copywriters: {', '.join(sorted(set(k for k in COPYWRITERS if k == k.upper() and k != 'CASSIO')))}",
    ]
    send_msg(chat_id, "\n".join(lines))


# ============================================================
# BOT POLLING
# ============================================================

def load_offset():
    if os.path.exists(OFFSET_FILE):
        with open(OFFSET_FILE) as f:
            return int(f.read().strip())
    return 0


def save_offset(offset):
    os.makedirs(os.path.dirname(OFFSET_FILE), exist_ok=True)
    with open(OFFSET_FILE, "w") as f:
        f.write(str(offset))


def handle_message(chat_id, text):
    # Verificar se ha conversa ativa esperando texto
    conv = get_conv(chat_id)
    if conv and conv["step"].startswith("criar_"):
        if handle_criar_text(chat_id, text):
            return

    # Verificar se está esperando período digitado para rpc
    if chat_id in _pending_perf_criativos:
        del _pending_perf_criativos[chat_id]
        # Parse DD/MM-DD/MM or DD/MM a DD/MM
        text_clean_rpc = text.strip()
        m = re.match(r"(\d{2}/\d{2}(?:/\d{4})?)\s*[-aA]\s*(\d{2}/\d{2}(?:/\d{4})?)", text_clean_rpc)
        if m:
            d1, d2 = m.group(1), m.group(2)
            year = datetime.now().year
            try:
                if len(d1) == 5: d1 = f"{d1}/{year}"
                if len(d2) == 5: d2 = f"{d2}/{year}"
                df = datetime.strptime(d1, "%d/%m/%Y").strftime("%Y-%m-%d")
                dt = datetime.strptime(d2, "%d/%m/%Y").strftime("%Y-%m-%d")
                rpc_execute(chat_id, df, dt)
            except ValueError:
                send_msg(chat_id, "Formato inválido. Use DD/MM-DD/MM ou DD/MM/YYYY-DD/MM/YYYY")
        else:
            send_msg(chat_id, "Formato inválido. Use DD/MM-DD/MM (ex: 01/04-21/04)")
        return

    text_clean = text.strip().lower().lstrip("/")
    parts = text_clean.split()
    cmd = parts[0] if parts else ""

    if cmd in ("help", "start"):
        send_msg(chat_id,
            "GPDR IMPERA — Comandos:\n\n"
            "/criar - Criar tarefas no ClickUp\n"
            "/corrigir - Corrigir nomenclatura automaticamente\n"
            "/auditoria - Verificar nomenclatura de tarefas\n"
            "/producao - Relatorio de producao semanal\n"
            "/relatorio - Gerar relatorios\n"
            "/relatorio_performance_criativos - Performance por criativo/copywriter\n"
            "/briefing - Briefing diario (performance, gestores, ads, esteira)\n"
            "/status - Status do bot\n"
            "/help - Esta mensagem\n\n"
            "Tambem funciona com texto livre:\n"
            "  '30 videos novos EM 2 hooks cassio'\n"
            "  'auditoria de nomenclatura'\n"
        )
    elif cmd == "criar":
        cmd_criar_start(chat_id)
    elif cmd == "corrigir":
        cmd_corrigir(chat_id)
    elif cmd == "auditoria":
        cmd_auditoria(chat_id)
    elif cmd == "producao":
        cmd_producao(chat_id)
    elif cmd == "relatorio":
        cmd_relatorio(chat_id)
    elif cmd == "status":
        cmd_status(chat_id)
    elif cmd in ("relatorio_performance_criativos", "rpc"):
        cmd_relatorio_performance_criativos(chat_id)
    elif cmd == "briefing":
        cmd_briefing(chat_id)
    elif cmd == "cancelar":
        if get_conv(chat_id):
            clear_conv(chat_id)
            send_msg(chat_id, "Operacao cancelada.")
    else:
        # Ignorar mensagens desconhecidas (nao interferir)
        pass


def handle_callback(callback_id, chat_id, data):
    parts = data.split("|")
    cmd = parts[0]
    field = parts[1] if len(parts) > 1 else ""
    value = parts[2] if len(parts) > 2 else ""

    answer_callback(callback_id)

    if cmd == "criar":
        handle_criar_callback(chat_id, field, value)

    elif cmd == "fix":
        if field == "cancel":
            clear_conv(chat_id)
            send_msg(chat_id, "Correcao cancelada.")
        elif field in ("all", "execute"):
            conv = get_conv(chat_id)
            if conv:
                fixable = conv["data"].get("fixable") or conv["data"].get("fixable_corrigir", [])
                if fixable:
                    fix_execute(chat_id, fixable)
                else:
                    send_msg(chat_id, "Nenhuma correcao pendente.")
            clear_conv(chat_id)

    elif cmd == "rpc":
        if field == "period":
            # value = "20260414_20260420"
            d1 = datetime.strptime(value[:8], "%Y%m%d").strftime("%Y-%m-%d")
            d2 = datetime.strptime(value[9:], "%Y%m%d").strftime("%Y-%m-%d")
            rpc_execute(chat_id, d1, d2)
        elif field == "custom":
            _pending_perf_criativos[chat_id] = True
            send_msg(chat_id, "Digite o período no formato DD/MM-DD/MM\nExemplo: 01/04-21/04")

    elif cmd == "rel":
        if field == "producao":
            cmd_producao(chat_id)
        elif field == "mensal":
            send_msg(chat_id, "Gerando relatorio mensal...")
            try:
                import subprocess
                result = subprocess.run(
                    [sys.executable, os.path.expanduser("~/Scripts/relatorio_mensal_arquivo_morto_v2.py"), "--dry"],
                    capture_output=True, text=True, timeout=120,
                )
                output = result.stdout or "Sem dados."
                send_msg(chat_id, output[:4000])
            except Exception as e:
                send_msg(chat_id, f"Erro: {e}")
        elif field == "auditoria":
            cmd_auditoria(chat_id)


def bot_poll_once():
    offset = load_offset()
    try:
        result = tg_request("getUpdates", {"offset": offset + 1, "timeout": 30})
    except Exception:
        return

    for update in result.get("result", []):
        uid = update["update_id"]

        msg = update.get("message", {})
        if msg:
            chat_id = msg.get("chat", {}).get("id")
            text = msg.get("text", "")
            if chat_id and text:
                handle_message(chat_id, text)

        cb = update.get("callback_query", {})
        if cb:
            cb_id = cb.get("id")
            chat_id = cb.get("message", {}).get("chat", {}).get("id")
            data = cb.get("data", "")
            if chat_id and data:
                handle_callback(cb_id, chat_id, data)

        save_offset(uid)


def cmd_bot():
    global BOT_START_TIME
    if not TELEGRAM_TOKEN:
        print("TELEGRAM_GPDR_TOKEN nao configurado.")
        sys.exit(1)

    BOT_START_TIME = datetime.now()
    print(f"[{BOT_START_TIME.isoformat()}] Bot GPDR IMPERA iniciado.")

    cmds = [
        {"command": "criar", "description": "Criar tarefas no ClickUp"},
        {"command": "corrigir", "description": "Corrigir nomenclatura automaticamente"},
        {"command": "auditoria", "description": "Verificar nomenclatura de tarefas"},
        {"command": "producao", "description": "Relatorio de producao semanal"},
        {"command": "relatorio", "description": "Gerar relatorios"},
        {"command": "relatorio_performance_criativos", "description": "Performance por criativo/copywriter"},
        {"command": "status", "description": "Status do bot"},
        {"command": "help", "description": "Lista de comandos"},
    ]
    tg_request("setMyCommands", {"commands": cmds})
    print("Comandos registrados.")

    while True:
        try:
            bot_poll_once()
        except KeyboardInterrupt:
            print("\nBot encerrado.")
            break
        except Exception as e:
            print(f"[{datetime.now().isoformat()}] Erro: {e}")
            _time.sleep(5)


# ============================================================
# AUTOFIX (crontab) — correcao silenciosa
# ============================================================

def autofix_run():
    """Roda autofix e envia resultado via Telegram se houver correcoes."""
    print(f"[{datetime.now().isoformat()}] Autofix de nomenclatura...")
    issues = []

    for list_id, list_name in [(LIST_COPY, "COPY")]:
        tasks = fetch_tasks(list_id)
        for task in tasks:
            name = task["name"].strip()
            if not name.startswith("["):
                continue
            fixed = _apply_autofix(name)
            if fixed != name:
                issues.append({
                    "id": task["id"],
                    "name": name,
                    "fixed": fixed,
                    "list": list_name,
                })

    if not issues:
        print("  Nenhuma correcao necessaria.")
        return

    fixed_count = 0
    errors = []
    for issue in issues:
        try:
            api_request("PUT", f"/task/{issue['id']}", {"name": issue["fixed"]})
            fixed_count += 1
            print(f"  Corrigido: {issue['name'][:50]} -> {issue['fixed'][:50]}")
        except Exception as e:
            errors.append(f"{issue['name'][:40]}: {e}")

    if TELEGRAM_CHAT_ID and fixed_count > 0:
        lines = [f"AUTOFIX NOMENCLATURA\n{fixed_count} tarefa(s) corrigida(s):\n"]
        for issue in issues[:10]:
            lines.append(f"  {issue['name'][:45]}")
            lines.append(f"  -> {issue['fixed'][:45]}")
            lines.append("")
        msg = "\n".join(lines)
        try:
            url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage"
            body = json.dumps({"chat_id": TELEGRAM_CHAT_ID, "text": msg}).encode()
            req = urllib.request.Request(url, data=body, method="POST")
            req.add_header("Content-Type", "application/json")
            urllib.request.urlopen(req)
        except Exception:
            pass

    print(f"  Total: {fixed_count} correcoes, {len(errors)} erros.")


# ============================================================
# MAIN
# ============================================================

if __name__ == "__main__":
    cmd = sys.argv[1] if len(sys.argv) > 1 else "bot"

    if cmd == "bot":
        cmd_bot()
    elif cmd == "autofix":
        autofix_run()
    else:
        print(__doc__)
