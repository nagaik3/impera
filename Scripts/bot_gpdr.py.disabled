#!/usr/bin/env python3
"""
Bot GPDR IMPERA — Telegram
Gestao de tarefas, nomenclatura e relatorios via Telegram.

Comandos:
  /criar       — Criar tarefas no ClickUp (conversacional)
  /corrigir    — Corrigir nomenclatura de tarefas
  /auditoria   — Rodar auditoria de nomenclatura agora
  /producao    — Gerar relatorio de producao semanal
  /relatorio   — Gerar relatorio (GPDR, mensal, etc.)
  /relatorio_performance_criativos — Performance por criativo/copywriter
  /briefing    — Briefing diario sob demanda
  /status      — Status do bot
  /help        — Lista de comandos

Uso:
  python3 bot_gpdr.py bot       # Bot interativo (long-polling)
  python3 bot_gpdr.py autofix   # Correcao automatica (crontab)
"""

