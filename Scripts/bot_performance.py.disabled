#!/usr/bin/env python3
"""
Bot IMPERA Performance — Telegram
Alertas proativos, comandos interativos com seletor de periodo,
auto reports (08:30 e 16:00), checagem horaria.

Uso:
  python3 bot_performance.py bot       # Bot interativo (long-polling)
  python3 bot_performance.py morning   # Auto report 08:30
  python3 bot_performance.py afternoon # Auto report 16:00
  python3 bot_performance.py check     # Checagem horaria de alertas
"""

