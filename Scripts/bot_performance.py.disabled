# BOT POLLING
# ============================================================

def load_offset():
    if os.path.exists(OFFSET_FILE):
        with open(OFFSET_FILE) as f:
            return int(f.read().strip())
    return 0


def save_offset(offset):
    os.makedirs(os.path.dirname(OFFSET_FILE), exist_ok=True)
    with open(OFFSET_FILE, "w") as f:
        f.write(str(offset))


COMMAND_HANDLERS = {
    "performance": cmd_performance,
    "campanhas": cmd_campanhas,
    "gestores": cmd_gestores,
    "copywriters": cmd_copywriters,
    "criativos": cmd_criativos,
    "fonte": cmd_fonte,
    "comparativo": cmd_comparativo,
    "validacao": cmd_validacao,
}


def parse_custom_dates(text):
    """Tenta parsear datas no formato DD/MM-DD/MM ou DD/MM/YYYY-DD/MM/YYYY.
    Retorna period_key no formato YYYYMMDD_YYYYMMDD ou None."""
    text = text.strip().replace(" ", "")
    # Aceita separadores: - ou " a " ou " A "
    for sep in ["-", "a", "A"]:
        if sep in text:
            parts = text.split(sep, 1)
            if len(parts) == 2:
                try:
                    year = datetime.now().year
                    d1_str, d2_str = parts[0].strip(), parts[1].strip()
                    if len(d1_str) > 5:  # DD/MM/YYYY
                        d1 = datetime.strptime(d1_str, "%d/%m/%Y")
                    else:  # DD/MM
                        d1 = datetime.strptime(f"{d1_str}/{year}", "%d/%m/%Y")
                    if len(d2_str) > 5:
                        d2 = datetime.strptime(d2_str, "%d/%m/%Y")
                    else:
                        d2 = datetime.strptime(f"{d2_str}/{year}", "%d/%m/%Y")
                    if d2 >= d1:
                        return f"{d1.strftime('%Y%m%d')}_{d2.strftime('%Y%m%d')}"
                except ValueError:
                    continue
    return None


def handle_message(chat_id, text):
    # Verifica se ha periodo customizado pendente (usuario digitando datas)
    if chat_id in _pending_custom_period:
        pending = _pending_custom_period.pop(chat_id)
        period_key = parse_custom_dates(text.strip())
        if period_key:
            cmd = pending["command"]
            extra = pending.get("extra", "")
            if cmd in COMMAND_HANDLERS:
                safe_command(chat_id, COMMAND_HANDLERS[cmd], period_key)
            elif cmd == "oferta" and extra:
                safe_command(chat_id, cmd_oferta, period_key, extra)
            elif cmd == "gestor" and extra:
                safe_command(chat_id, cmd_gestor, period_key, extra)
            elif cmd == "gerar":
                cmd_gerar_select_type(chat_id, period_key)
            else:
                safe_command(chat_id, cmd_performance, period_key)
            return
        else:
            send_msg(chat_id,
                "Formato invalido. Use DD/MM-DD/MM (ex: 01/04-15/04).\n"
                "Tente novamente ou use outro comando."
            )
            return

    text = text.strip().lower().lstrip("/")
    parts = text.split()
    cmd = parts[0] if parts else ""
    extra = " ".join(parts[1:])

    # Suporte a datas inline: /performance 01/04-15/04
    if cmd in COMMANDS_WITH_PERIOD and extra:
        period_key = parse_custom_dates(extra)
        if period_key:
            cmd_extra = ""
            if cmd == "oferta":
                cmd_extra = extra.split()[-1] if len(extra.split()) > 1 else ""
                safe_command(chat_id, cmd_oferta, period_key, cmd_extra) if cmd_extra else safe_command(chat_id, cmd_performance, period_key)
            elif cmd == "gestor":
                cmd_extra = extra.split()[-1] if len(extra.split()) > 1 else ""
                safe_command(chat_id, cmd_gestor, period_key, cmd_extra) if cmd_extra else safe_command(chat_id, cmd_gestores, period_key)
            elif cmd in COMMAND_HANDLERS:
                safe_command(chat_id, COMMAND_HANDLERS[cmd], period_key)
            return

    if cmd == "help" or cmd == "start":
        send_msg(chat_id,
            "IMPERA Performance - Comandos:\n\n"
            "/performance - Visao geral por oferta\n"
            "/campanhas - Performance por campanha\n"
            "/gestores - Ranking gestores de trafego\n"
            "/copywriters - Ranking copywriters\n"
            "/criativos - Top criativos com copy/editor\n"
            "/oferta [sigla] - Detalhe de oferta (ex: /oferta EM)\n"
            "/gestor [nome] - Detalhe de gestor (ex: /gestor lucas)\n"
            "/fonte - Performance por fonte de trafego\n"
            "/comparativo - Comparar periodo atual vs anterior\n"
            "/resumo - Resumo rapido do dia (24h)\n"
            "/alertas - Alertas ativos\n"
            "/forecast - Projecao do dia baseado no ritmo atual\n"
            "/validacao - Criativos por nivel (Super Cerebro V5)\n"
            "/nichos - Nichos e ofertas disponiveis\n"
            "/gerar - Gerar relatorio (prompt Docs ou documento)\n"
            "/doc - Gera PDF do ultimo relatorio\n"
            "/status - Status do bot\n"
            "/help - Esta mensagem"
        )
    elif cmd == "alertas":
        safe_command(chat_id, cmd_alertas)
    elif cmd == "resumo":
        safe_command(chat_id, cmd_resumo)
    elif cmd == "status":
        safe_command(chat_id, cmd_status)
    elif cmd == "doc":
        safe_command(chat_id, cmd_doc)
    elif cmd == "forecast":
        safe_command(chat_id, cmd_forecast)
    elif cmd == "nichos":
        safe_command(chat_id, cmd_nichos)
    elif cmd == "gerar":
        send_period_selector(chat_id, "gerar", "")
    elif cmd in COMMANDS_WITH_PERIOD:
        send_period_selector(chat_id, cmd, extra)
    else:
        return  # Ignora comandos desconhecidos


def handle_callback(callback_id, chat_id, data):
    """Processa callback de inline button (seletor de periodo)."""
    parts = data.split("|")
    cmd = parts[0]
    period = parts[1] if len(parts) > 1 else "7d"
    extra = parts[2] if len(parts) > 2 else ""

    answer_callback(callback_id)

    # Personalizar — mostra presets inteligentes
    if cmd == "custom_period":
        # period aqui e o comando original, extra e o extra original
        send_custom_period_selector(chat_id, period, extra)
        return

    # Digitar datas — salva estado e pede input
    if cmd == "custom_type":
        _pending_custom_period[chat_id] = {"command": period, "extra": extra}
        send_msg(chat_id,
            "Digite o periodo no formato DD/MM-DD/MM\n"
            "Exemplo: 01/04-15/04\n\n"
            "Ou com ano: 01/04/2026-15/04/2026"
        )
        return

    if cmd in COMMAND_HANDLERS:
        safe_command(chat_id, COMMAND_HANDLERS[cmd], period)
    elif cmd == "oferta":
        if extra:
            safe_command(chat_id, cmd_oferta, period, extra)
        else:
            safe_command(chat_id, cmd_performance, period)
    elif cmd == "gestor":
        if extra:
            safe_command(chat_id, cmd_gestor, period, extra)
        else:
            safe_command(chat_id, cmd_gestores, period)
    elif cmd == "gerar":
        cmd_gerar_select_type(chat_id, period)
    elif cmd == "gerar_type":
        # period aqui e o report_type, extra e o period_key
        cmd_gerar_select_output(chat_id, period, extra)
    elif cmd == "gerar_prompt":
        cmd_gerar_prompt(chat_id, period, extra)
    elif cmd == "gerar_doc":
        cmd_gerar_doc(chat_id, period, extra)


def bot_poll_once():
    offset = load_offset()
    try:
        result = tg_request("getUpdates", {"offset": offset + 1, "timeout": 30})
    except Exception as e:
        print(f"[{datetime.now().isoformat()}] Poll error: {e}")
        return

    for update in result.get("result", []):
        uid = update["update_id"]

        # Message
        msg = update.get("message", {})
        if msg:
            chat_id = msg.get("chat", {}).get("id")
            text = msg.get("text", "")
            if chat_id and text:
                handle_message(chat_id, text)

        # Callback query (inline button click)
        cb = update.get("callback_query", {})
        if cb:
            cb_id = cb.get("id")
            chat_id = cb.get("message", {}).get("chat", {}).get("id")
            data = cb.get("data", "")
            if chat_id and data:
                handle_callback(cb_id, chat_id, data)

        save_offset(uid)


def cmd_bot():
    global BOT_START_TIME
    if not TELEGRAM_TOKEN:
        print("TELEGRAM_PERF_TOKEN nao configurado.")
        sys.exit(1)

    BOT_START_TIME = datetime.now()
    print(f"[{BOT_START_TIME.isoformat()}] Bot IMPERA Performance iniciado.")

    # Registra comandos
    cmds = [
        {"command": "performance", "description": "Visao geral por oferta"},
        {"command": "campanhas", "description": "Performance por campanha"},
        {"command": "gestores", "description": "Ranking gestores de trafego"},
        {"command": "copywriters", "description": "Ranking copywriters"},
        {"command": "criativos", "description": "Top criativos com copy/editor"},
        {"command": "fonte", "description": "Performance por fonte de trafego"},
        {"command": "comparativo", "description": "Comparar periodo atual vs anterior"},
        {"command": "resumo", "description": "Resumo rapido do dia (24h)"},
        {"command": "alertas", "description": "Alertas ativos"},
        {"command": "forecast", "description": "Projecao do dia baseado no ritmo atual"},
        {"command": "validacao", "description": "Criativos por nivel (Super Cerebro V5)"},
        {"command": "nichos", "description": "Nichos e ofertas disponiveis"},
        {"command": "gerar", "description": "Gerar relatorio (prompt Docs ou documento)"},
        {"command": "doc", "description": "Gera PDF do ultimo relatorio"},
        {"command": "status", "description": "Status do bot"},
        {"command": "help", "description": "Lista de comandos"},
    ]
    tg_request("setMyCommands", {"commands": cmds})
    print("Comandos registrados.")

    while True:
        try:
            bot_poll_once()
        except KeyboardInterrupt:
            print("\nBot encerrado.")
            break
        except Exception as e:
            print(f"[{datetime.now().isoformat()}] Erro: {e}")
            _time.sleep(5)


# ============================================================
# MAIN
# ============================================================

if __name__ == "__main__":
    cmd = sys.argv[1] if len(sys.argv) > 1 else "bot"

    if cmd == "bot":
        cmd_bot()
    elif cmd == "morning":
        auto_report_morning(TELEGRAM_CHAT_ID)
    elif cmd == "afternoon":
        auto_report_afternoon(TELEGRAM_CHAT_ID)
    elif cmd == "check":
        hourly_check(TELEGRAM_CHAT_ID)
    else:
        print(__doc__)
